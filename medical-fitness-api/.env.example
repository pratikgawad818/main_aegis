# Google Gemini (get a key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=1024
GEMINI_THINKING_BUDGET=0          # 0 = thinking off (cheaper / faster)
GEMINI_TIMEOUT_SECONDS=60         # max seconds to wait for a Gemini reply

# Verification settings
MAX_PDF_PAGES=5                   # pages sent to the model
MAX_FILE_SIZE_MB=10               # max upload size (MB)
CERTIFICATE_VALIDITY_DAYS=180     # how recent the certificate must be
NAME_MATCH_THRESHOLD=75           # name match score needed (0-100)

# API access (optional)
API_KEY=                          # if set, callers must send an X-API-Key header
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
